GNS_ENVIRONMENT=development
GNS_DATABASE_URL=sqlite:///./gns.db
GNS_BROKER_URL=amqp://guest:guest@localhost:5672//
GNS_RESULT_BACKEND_URL=redis://localhost:6379/0
GNS_ALLOW_DEV_IDENTITY=true
GNS_API_KEY_PEPPER=replace-with-at-least-16-random-characters
GNS_PROVIDER_SECRET_KEY=replace-with-a-separate-random-secret
GNS_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
GNS_PLATFORM_DEFAULT_LOCALE=en
GNS_MAX_REQUEST_BYTES=1048576
GNS_OIDC_ISSUER=
GNS_OIDC_AUDIENCE=

NEXT_PUBLIC_GNS_API_URL=http://localhost:5000
NEXT_PUBLIC_GNS_TENANT_ID=iitdeveloper
NEXT_PUBLIC_GNS_APP_ID=iitdeveloper
